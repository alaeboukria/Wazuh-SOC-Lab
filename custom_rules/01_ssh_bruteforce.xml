<group name="syslog, sshd, custom_bruteforce,">

  <rule id="100001" level="3">
    <if_sid>5716</if_sid> <description>Échec d'authentification SSH détecté.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <rule id="100002" level="12" frequency="5" timeframe="120">
    <if_matched_sid>100001</if_matched_sid>
    <same_source_ip />
    <description>Attaque par Force Brute SSH détectée depuis la même adresse IP.</description>
    <mitre>
      <id>T1110</id> </mitre>
    <group>authentication_failures,pci_dss_10.2.4,pci_dss_10.2.5,pci_dss_11.4,</group>
  </rule>

</group>